pipeline {
    agent { label 'fe' }

    environment {
        REPO_URL = 'https://github.com/ShubhamDeshmukh-0168/python-backend-testing.git'
    }

    stages {

        stage('Clone Repository') {
            steps {
                git branch: 'main', url: "${REPO_URL}"
            }
        }
        

        stage('Install Python & Pip') {
            steps {
                sh '''
                sudo yum update -y
                sudo yum install -y python3 python3-pip
                python3 --version
                pip3 --version || true
                '''
            }
        }

        stage('Install Requirements') {
            steps {
                sh '''
                echo "Current directory:"
                pwd
                ls -l

                echo "Installing requirements..."
                
                # Install from correct folder
                if [ -f requirements.txt ]; then
                    python3 -m pip install -r requirements.txt
                elif [ -f Frontend-flask-server/requirements.txt ]; then
                    cd Frontend-flask-server
                    python3 -m pip install -r requirements.txt
                else
                    echo "requirements.txt not found"
                fi
                '''
            }
        }

        stage('Run Flask App') {
            steps {
                sh '''
                cd $WORKSPACE

                echo "Stopping old processes..."
                pkill -f app.py || true
                pkill -f backend.py || true

                echo "Starting Backend..."
                nohup python3 backend/backend.py > backend.log 2>&1 &

                sleep 5

                echo "Starting Frontend..."
                nohup python3 Frontend-flask-server/app.py > frontend.log 2>&1 &

                sleep 5

                echo "Running processes:"
                ps -ef | grep python
                '''
            }
        }
        #---------------no need to run backend build it will auto run----------------
        #stage('Start Backend') { 
    #steps {
     #   build job: 'python-backend'
    #}
#}

    }
}










